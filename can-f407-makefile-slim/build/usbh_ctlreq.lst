 767:Middlewares/ST/STM32_USB_Host_Library/Core/Src/usbh_ctlreq.c **** #endif /* (USBH_USE_OS == 1U) */
 768:Middlewares/ST/STM32_USB_Host_Library/Core/Src/usbh_ctlreq.c ****       break;
 769:Middlewares/ST/STM32_USB_Host_Library/Core/Src/usbh_ctlreq.c **** 
 770:Middlewares/ST/STM32_USB_Host_Library/Core/Src/usbh_ctlreq.c ****     case CMD_WAIT:
