 116:Src/main.c    ****   // --- STEP 1: CAN Filter Configuration ---
 117:Src/main.c    ****   // Setting all IDs and Masks to 0 accepts EVERY incoming message for testing purposes.
 118:Src/main.c    ****   CAN_FilterTypeDef sFilterConfig;
 119:Src/main.c    **** 
 120:Src/main.c    ****   sFilterConfig.FilterBank = 0;
 121:Src/main.c    ****   sFilterConfig.FilterMode = CAN_FILTERMODE_IDMASK;
 122:Src/main.c    ****   sFilterConfig.FilterScale = CAN_FILTERSCALE_32BIT;
 123:Src/main.c    ****   sFilterConfig.FilterIdHigh = 0x0000;
 124:Src/main.c    ****   sFilterConfig.FilterIdLow = 0x0000;
 125:Src/main.c    ****   sFilterConfig.FilterMaskIdHigh = 0x0000;
 126:Src/main.c    ****   sFilterConfig.FilterMaskIdLow = 0x0000;
 127:Src/main.c    ****   sFilterConfig.FilterFIFOAssignment = CAN_RX_FIFO0;
 128:Src/main.c    ****   sFilterConfig.FilterActivation = ENABLE;
 129:Src/main.c    ****   sFilterConfig.SlaveStartFilterBank = 14;
 130:Src/main.c    **** 
 131:Src/main.c    ****   if (HAL_CAN_ConfigFilter(&hcan1, &sFilterConfig) != HAL_OK)
 132:Src/main.c    ****   {
 133:Src/main.c    ****       Error_Handler();
 134:Src/main.c    ****   }
 135:Src/main.c    **** 
 136:Src/main.c    ****   // --- STEP 2: Start the CAN Peripheral ---
 137:Src/main.c    ****   if (HAL_CAN_Start(&hcan1) != HAL_OK)
 138:Src/main.c    ****   {
 139:Src/main.c    ****       Error_Handler();
 140:Src/main.c    ****   }
 141:Src/main.c    **** 
 142:Src/main.c    ****   // --- STEP 3: Activate RX Interrupt Notifications ---
 143:Src/main.c    ****   if (HAL_CAN_ActivateNotification(&hcan1, CAN_IT_RX_FIFO0_MSG_PENDING) != HAL_OK)
 144:Src/main.c    ****   {
 145:Src/main.c    ****       Error_Handler();
ARM GAS  /tmp/ccDtClUL.s 			page 4


 146:Src/main.c    ****   }
 147:Src/main.c    **** 
 148:Src/main.c    ****   // --- STEP 4: Prepare Tx Message Header Attributes ---
 149:Src/main.c    ****   // TxHeader.StdId = 0x102;          // Example Message Identifier (Standard ID)
 150:Src/main.c    ****   TxHeader.RTR = CAN_RTR_DATA;     // We are sending data frames, not remote requests
 151:Src/main.c    ****   TxHeader.IDE = CAN_ID_STD;       // Standard 11-bit identifier format
 152:Src/main.c    ****   // TxHeader.DLC = 4;                // Sending 4 bytes of data payload
 153:Src/main.c    ****   TxHeader.TransmitGlobalTime = DISABLE;
 154:Src/main.c    **** 
 155:Src/main.c    ****   /* USER CODE END 2 */
 156:Src/main.c    **** 
 157:Src/main.c    ****   /* Infinite loop */
 158:Src/main.c    ****   /* USER CODE BEGIN WHILE */
 159:Src/main.c    ****   while (1)
 160:Src/main.c    ****   {
 161:Src/main.c    ****     /* USER CODE END WHILE */
 162:Src/main.c    ****     MX_USB_HOST_Process();
 163:Src/main.c    **** 
 164:Src/main.c    ****     // Showcase Loop
 165:Src/main.c    ****     if (0)
 166:Src/main.c    ****     {
 167:Src/main.c    ****       // ==========================================
 168:Src/main.c    ****       // Section 1: Headlights
 169:Src/main.c    ****       // ==========================================
 170:Src/main.c    ****       TxHeader.StdId = 0x102;          // Set the ID
 171:Src/main.c    ****       TxHeader.DLC = 1;                // 1 byte of data
 172:Src/main.c    **** 
 173:Src/main.c    ****       // Activate Headlights
 174:Src/main.c    ****       TxData[0] = 0x11;
 175:Src/main.c    ****       
 176:Src/main.c    ****       // Push Message 1 into a free hardware mailbox
 177:Src/main.c    ****       if (HAL_CAN_AddTxMessage(&hcan1, &TxHeader, TxData, &TxMailbox) != HAL_OK)
 178:Src/main.c    ****       {
 179:Src/main.c    ****           // Handle transmission error
 180:Src/main.c    ****       }
 181:Src/main.c    ****       HAL_Delay(1000);
 182:Src/main.c    ****       
 183:Src/main.c    ****       // Deactivate Headlights
 184:Src/main.c    ****       TxData[0] = 0x22;
 185:Src/main.c    ****       if (HAL_CAN_AddTxMessage(&hcan1, &TxHeader, TxData, &TxMailbox) != HAL_OK) {}
 186:Src/main.c    ****       HAL_Delay(1000);
 187:Src/main.c    **** 
 188:Src/main.c    ****       // ==========================================
 189:Src/main.c    ****       // Section 2: Bonnet
 190:Src/main.c    ****       // ==========================================
 191:Src/main.c    ****       TxHeader.StdId = 0x203;
 192:Src/main.c    ****       TxHeader.DLC = 1;
 193:Src/main.c    **** 
 194:Src/main.c    ****       // Open bonnet
 195:Src/main.c    ****       TxData[0] = 0x11;
 196:Src/main.c    ****       if (HAL_CAN_AddTxMessage(&hcan1, &TxHeader, TxData, &TxMailbox) != HAL_OK) {}
 197:Src/main.c    ****       HAL_Delay(1000);
 198:Src/main.c    ****       
 199:Src/main.c    ****       // Close bonnet
 200:Src/main.c    ****       TxData[0] = 0x22;
 201:Src/main.c    ****       if (HAL_CAN_AddTxMessage(&hcan1, &TxHeader, TxData, &TxMailbox) != HAL_OK) {}
 202:Src/main.c    ****       HAL_Delay(1000);
ARM GAS  /tmp/ccDtClUL.s 			page 5


 203:Src/main.c    **** 
 204:Src/main.c    ****       // ==========================================
 205:Src/main.c    ****       // Section 3: Wheels
 206:Src/main.c    ****       // ==========================================
 207:Src/main.c    ****       TxHeader.StdId = 0x304;
 208:Src/main.c    ****       TxHeader.DLC = 1;
 209:Src/main.c    **** 
 210:Src/main.c    ****       // Spin wheels
 211:Src/main.c    ****       TxData[0] = 0x11;
 212:Src/main.c    ****       if (HAL_CAN_AddTxMessage(&hcan1, &TxHeader, TxData, &TxMailbox) != HAL_OK) {}
 213:Src/main.c    ****       HAL_Delay(1000);
 214:Src/main.c    ****       
 215:Src/main.c    ****       // Stop wheels
 216:Src/main.c    ****       TxData[0] = 0x22;
 217:Src/main.c    ****       if (HAL_CAN_AddTxMessage(&hcan1, &TxHeader, TxData, &TxMailbox) != HAL_OK) {}
 218:Src/main.c    ****       HAL_Delay(1000);
 219:Src/main.c    ****     }
 220:Src/main.c    ****   }
 221:Src/main.c    ****   /* USER CODE END 3 */
 222:Src/main.c    **** }
